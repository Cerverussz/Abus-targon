# Telegram Bot credentials.
# 1. Crea un bot con @BotFather y copia el token aquí.
# 2. Obtén tu chat_id (p. ej. escribiéndole al bot y consultando
#    https://api.telegram.org/bot<TOKEN>/getUpdates).
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWxyZ
TELEGRAM_CHAT_ID=123456789

# Servicio de scraping para tiendas con anti-bot (LordGun/Cloudflare, Abus/Akamai).
# Necesario solo para tiendas con method: scraper en stores.yaml.
# SCRAPER_PROVIDER puede ser: scraperapi | zenrows | scrapingbee | custom
SCRAPER_PROVIDER=scraperapi
SCRAPER_API_KEY=tu_api_key_del_servicio
# Para SCRAPER_PROVIDER=custom (cualquier otro proveedor con API tipo GET):
# SCRAPER_BASE_URL=https://api.miproveedor.com/
# SCRAPER_PARAMS={"render":"true","premium":"true"}
# SCRAPER_KEY_PARAM=api_key
# SCRAPER_URL_PARAM=url
# SCRAPER_TIMEOUT=90

# Opcional: ruta a otro archivo de config de tiendas (por defecto config/stores.yaml)
# STORES_CONFIG=config/stores.yaml

# Opcional: ruta al archivo de estado (por defecto state.json)
# STATE_FILE=state.json

# Opcional: nivel de log (DEBUG, INFO, WARNING). Por defecto INFO.
# LOG_LEVEL=INFO
